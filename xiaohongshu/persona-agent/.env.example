# OpenAI 或任意兼容接口（DeepSeek、通义、SiliconFlow 等）
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# 人设 skills 根目录 & 默认人设 ID（对应 skills/<persona_id>/）
PERSONA_SKILLS_DIR=skills
DEFAULT_PERSONA_ID=zhang_zong

# 双人对话默认人设
DUEL_PERSONA_A=zhang_zong
DUEL_PERSONA_B=xiao_hong

# HTTP 服务
AGENT_HOST=127.0.0.1
AGENT_PORT=8765
AGENT_API_URL=http://127.0.0.1:8765/v1/chat

# 串口（bridge / duel）
SERIAL_PORT=/dev/cu.usbmodem1101
SERIAL_BAUDRATE=2000000
